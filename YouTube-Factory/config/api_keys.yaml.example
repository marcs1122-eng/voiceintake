# ============================================================================
# API Keys Configuration - COPY to api_keys.yaml and fill in your keys
# NEVER commit api_keys.yaml to version control!
# ============================================================================

anthropic:
  api_key: "sk-ant-XXXX"
  model: "claude-sonnet-4-6"

higgsfield:
  api_key: "hf-XXXX"
  base_url: "https://api.higgsfield.ai/v1"

cinema_studio:
  api_key: "cs-XXXX"
  base_url: "https://api.cinemastudio.ai/v3"
  model: "seedance-2.0"

# Note: Voice narration (including Atlas) is provided by Higgsfield above.
# No separate Atlas API key is needed.

youtube:
  client_id: "XXXX.apps.googleusercontent.com"
  client_secret: "XXXX"
  refresh_token: "XXXX"

tiktok:
  client_key: "XXXX"
  client_secret: "XXXX"
  access_token: "XXXX"

instagram:
  access_token: "XXXX"
  business_account_id: "XXXX"

serpapi:
  api_key: "XXXX"
