# ============================================================================
# API Keys Configuration - COPY to api_keys.yaml and fill in your keys
# NEVER commit api_keys.yaml to version control!
# ============================================================================

anthropic:
  api_key: "sk-ant-XXXX"
  model: "claude-sonnet-4-6"

higgsfield:
  # Higgsfield provides everything visual and audio:
  #  - Images (Nano Banana Pro)
  #  - Voices (Atlas + many others)
  #  - Video (Cinema Studio 3.0 with Seedance 2.0)
  api_key: "hf-XXXX"
  base_url: "https://api.higgsfield.ai/v1"
  video_model: "seedance-2.0"

# Note: Voice narration (including Atlas) and video generation
# (Cinema Studio 3.0 / Seedance 2.0) are both handled by Higgsfield above.
# No separate API keys are needed for voice or video.

youtube:
  client_id: "XXXX.apps.googleusercontent.com"
  client_secret: "XXXX"
  refresh_token: "XXXX"

tiktok:
  client_key: "XXXX"
  client_secret: "XXXX"
  access_token: "XXXX"

instagram:
  access_token: "XXXX"
  business_account_id: "XXXX"

serpapi:
  api_key: "XXXX"
